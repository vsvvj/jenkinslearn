pipeline {
    agent { docker { image 'python:3.9' } }
    options {
         timeout(time:1, unit: 'HOURS')
         skipDefaultCheckout()
         retry(3)
    }
    environment {
         MY_VAR = "xyz"
         PROD_SERVER = credentials('userpass2')
    }
    stages {
        stage('Build') {
           steps {
               withCredentials([usernamePassword(credentialsId: 'userpass1', passwordVariable: 'mypassword', usernameVariable: 'myusername')]){
               echo "${myusername}"
               echo "${mypassword}"
               }
               echo "Running ${env.BUILD_ID} on ${env.JENKINS_URL}"
               echo "${PROD_SERVER}"
               echo "${PROD_SERVER_USR}"
               echo "${PROD_SERVER_PSW}"
           }
        }
        stage('Hello') {
            steps {
                echo 'Hello World'
                echo "My environment varibale is ${MY_VAR}"
            }
        }
        stage('checkout'){
            steps {
                git url: 'https://github.com/vsvvj/jenkinslearn.git', branch: 'main'
                sh 'ls -lrt'
            }
        }
        stage('env_variables'){
            environment {
                 VAR1 = "var1"
                 VAR2 = "var2"
            }
            steps {
                 echo "My first var at stage ${VAR1}"
                 echo "My second var at stage ${VAR2}"
            }
        }
        stage('parallel') {
            parallel {
              stage("job1"){
                steps {
                   sh "sleep 30"
                }
              }
              stage('job2'){
                steps {
                   sh "sleep 30"
                }
              }  
            }
        }
    }
}

